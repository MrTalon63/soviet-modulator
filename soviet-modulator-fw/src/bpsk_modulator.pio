.program bpsk_modulator
; BPSK Modulator - outputs one bit per symbol period
; 
; Bit order: MSB first from each byte
; Autopull feeds a new byte every 8 shifted bits

.wrap_target
    out pins, 1             ; Emit one bit per symbol period
.wrap

; Clock configuration:
; Symbol rate = sys_clock / clkdiv
; For sys_clock = 150 MHz and symbolrate_hz:
; clkdiv = 150_000_000 / symbolrate_hz